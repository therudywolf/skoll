{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "codebase_search",
  "description": "Semantic search over the indexed workspace. Returns top-k chunks with file paths, line ranges, and similarity scores. Use this BEFORE asking the user 'where is X' — search first. Index is built via POST /api/workspaces/{id}/index.",
  "phase": "1",
  "kind": "read",
  "requires_approval": false,
  "auto_approve_default": true,
  "path_args": [],
  "parameters": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "Natural-language query, e.g. 'where do we validate auth tokens'."
      },
      "top_k": {
        "type": "integer",
        "minimum": 1,
        "maximum": 20,
        "default": 5
      },
      "path_filter": {
        "type": "string",
        "description": "Optional glob filter, e.g. 'src/**/*.py'."
      }
    },
    "required": ["query"],
    "additionalProperties": false
  },
  "result_schema": {
    "type": "object",
    "required": ["query", "hits"],
    "properties": {
      "query": {"type": "string"},
      "hits": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["path", "score", "snippet"],
          "properties": {
            "path": {"type": "string"},
            "start_line": {"type": "integer"},
            "end_line": {"type": "integer"},
            "score": {"type": "number"},
            "snippet": {"type": "string", "description": "Wrapped in <untrusted_content>."}
          }
        }
      }
    }
  }
}
