# Force LF line endings inside the repo, regardless of OS.
# Critical because the project owner is on Windows but the sandbox / CI is on Linux.
* text=auto eol=lf

# Windows-only scripts keep CRLF
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Explicit binary types — never run line-ending normalization on these.
# Note: do NOT add inline comments after attribute names — git treats `#` as
# an attribute. Comments must be on their own line.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.tgz   binary
*.bz2   binary
*.7z    binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary

# SVG is XML — keep it text so diffs work.
*.svg   text

# Lock files keep their exact formatting (no auto-conversion).
pnpm-lock.yaml -text
uv.lock        -text

# Generated files — mark for GitHub Linguist to exclude from language stats.
frontend/src/lib/api/types.gen.ts        li