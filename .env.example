# Skoll — example environment variables
# Copy to .env (gitignored) and fill in.

# --- LM Studio ---
SKOLL_LMSTUDIO_BASE_URL=http://127.0.0.1:1234
SKOLL_LMSTUDIO_API_KEY=
SKOLL_LMSTUDIO_API_MODE=native            # native | openai
SKOLL_LMSTUDIO_DEFAULT_MODEL=
SKOLL_LMSTUDIO_TIMEOUT_SECONDS=600

# --- Backend server ---
SKOLL_HOST=127.0.0.1
SKOLL_PORT=8000
SKOLL_LOG_LEVEL=INFO
SKOLL_LOG_FORMAT=json

# --- Workspace ---
SKOLL_WORKSPACE_ROOT=./workspaces
SKOLL_CACHE_DIR=./.skoll_cache
SKOLL_DB_PATH=./.skoll_cache/skoll.sqlite

# --- Search ---
SKOLL_SEARXNG_URL=http://localhost:8089
SKOLL_SEARCH_PRIMARY=searxng              # searxng | duckduckgo
SKOLL_JINA_READER_API_KEY=                # optional, free tier 50K/mo without

# --- Sandbox ---
SKOLL_SANDBOX_IMAGE=skoll/sandbox:dev
SKOLL_SANDBOX_RUNTIME=runsc               # runsc (gVisor) | runc (DEV ONLY)
SKOLL_SANDBOX_BASH_TIMEOUT_SECONDS=30
SKOLL_SANDBOX_NETWORK_ALLOWLIST=host.docker.internal:1234,r.jina.ai,searxng:8080

# --- Agent ---
SKOLL_AGENT_MAX_ITERATIONS=20
SKOLL_AGENT_AUTO_APPROVE_READ_TOOLS=true
SKOLL_AGENT_AUTO_APPROVE_WRITE_TOOLS=false
SKOLL_AGENT_AUTO_APPROVE_EXEC_TOOLS=false

# --- RAG ---
SKOLL_EMBEDDING_MODEL=                    # e.g. nomic-embed-text-v1.5
SKOLL_RAG_CHUNK_SIZE_TOKENS=1024
SKOLL_RAG_CHUNK_OVERLAP_TOKENS=128
SKOLL_FAISS_INDEX_PATH=./.skoll_cache/faiss
